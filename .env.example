OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# ElevenLabs is optional. Leave these blank to use browser speech only.
# Drop Italian / Italian-accented ElevenLabs voice IDs here as you find them.
# The app routes by speaker ID, so swapping voices does not require code changes.
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_MAX_TTS_CHARS=900
ELEVENLABS_VOICE_NARRATOR=
ELEVENLABS_VOICE_DON_VITO=
ELEVENLABS_VOICE_SALVATORE=
ELEVENLABS_VOICE_ROSA=
ELEVENLABS_VOICE_VINCENZO=
ELEVENLABS_VOICE_CARMELA=
